.DS_Store

# Local browser/session artifacts. Do not commit cookies, profiles, or Playwright traces.
.browser-profiles/
.playwright-mcp/

# Node dependencies and generated package caches.
node_modules/

# Local secrets and machine-specific environment files.
.env
.env.*
*.local
secrets.env

# Logs and transient output.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Skill evaluation workspaces are generated run artifacts, not installable skill content.
hotel-search-cn-workspace/
